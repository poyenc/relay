{
  "hooks": {
    "Stop": [
      { "hooks": [ { "type": "command",
        "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/stop-hook.sh\"",
        "async": false } ] }
    ],
    "SessionStart": [
      { "matcher": "startup|resume",
        "hooks": [ { "type": "command",
          "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/session-start-hook.sh\"",
          "async": false } ] }
    ]
  }
}
